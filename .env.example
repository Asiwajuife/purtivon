# App
NEXT_PUBLIC_APP_URL=https://www.purtivon.com
# Google Analytics (GA4) — get from Analytics > Admin > Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Database (Vercel Postgres / Supabase / Neon)
DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://user:password@host:5432/dbname"
# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-min-32-chars
# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Seed (only needed when running prisma db seed)
SEED_ADMIN_PASSWORD=change-this-to-a-strong-password
