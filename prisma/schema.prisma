generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  EDITOR
  ADMIN
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  password    String
  role        Role         @default(USER)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  articles    Article[]
  submissions Submission[]
  @@index([role]) // optional index for querying by role
}

model Article {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  excerpt   String?
  imageUrl  String?      // new optional field for article image
  category  String?      // optional category
  readTime  Int?         // estimated reading time in minutes
  published Boolean  @default(true)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  @@index([published])
  @@index([category])
}

model Award {
  id          String       @id @default(cuid())
  title       String
  category    String
  recipient   String
  year        Int
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  submissions Submission[]
  @@index([year])
  @@index([category])
}

model Submission {
  id             String           @id @default(cuid())
  awardId        String
  userId         String
  companyName    String
  companyWebsite String?
  contactName    String
  contactEmail   String
  details        String
  additionalInfo String?
  status         SubmissionStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  award          Award            @relation(fields: [awardId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([awardId, userId])
  @@index([userId])
  @@index([status])
  @@index([companyName]) // optional index for searching submissions by company
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  createdAt      DateTime  @default(now())
  unsubscribedAt DateTime?
  resubscribedAt DateTime?
}
